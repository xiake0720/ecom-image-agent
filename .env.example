# 修改 `.env` 后需要重启 Streamlit 进程

# ------------------------------
# 基础运行配置
# ------------------------------
ECOM_IMAGE_AGENT_ENV=dev
ECOM_IMAGE_AGENT_ENABLE_MOCK_PROVIDERS=true
ECOM_IMAGE_AGENT_ENABLE_NODE_CACHE=true
ECOM_IMAGE_AGENT_ENABLE_FILE_LOG=true
ECOM_IMAGE_AGENT_LOG_LEVEL=INFO
ECOM_IMAGE_AGENT_PROVIDER_TIMEOUT_SECONDS=120
ECOM_IMAGE_AGENT_DEFAULT_FONT_PATH=assets/fonts/NotoSansSC-Regular.otf

# ------------------------------
# v2 固定业务默认值
# ------------------------------
ECOM_IMAGE_AGENT_DEFAULT_PLATFORM=tmall
ECOM_IMAGE_AGENT_DEFAULT_SHOT_COUNT=8
ECOM_IMAGE_AGENT_DEFAULT_IMAGE_ASPECT_RATIO=1:1
ECOM_IMAGE_AGENT_DEFAULT_IMAGE_SIZE=2K
ECOM_IMAGE_AGENT_ENABLE_OVERLAY_FALLBACK=true

# ------------------------------
# Provider 模式
# real: 使用 RunAPI
# mock: 使用本地占位 provider
# 当前项目只保留 v2 固定路由：
# text -> runapi_openai
# image -> runapi_gemini31
# ------------------------------
ECOM_IMAGE_AGENT_TEXT_PROVIDER_MODE=real
ECOM_IMAGE_AGENT_IMAGE_PROVIDER_MODE=real

# ------------------------------
# RunAPI 文本配置
# ------------------------------
ECOM_IMAGE_AGENT_RUNAPI_API_KEY=
ECOM_IMAGE_AGENT_RUNAPI_TEXT_API_KEY=
ECOM_IMAGE_AGENT_RUNAPI_TEXT_BASE_URL=https://runapi.co/v1
ECOM_IMAGE_AGENT_RUNAPI_TEXT_MODEL=gpt-5-nano

# ------------------------------
# RunAPI 图片配置
# ------------------------------
ECOM_IMAGE_AGENT_RUNAPI_IMAGE_BASE_URL=https://runapi.co
ECOM_IMAGE_AGENT_RUNAPI_IMAGE_MODEL=gemini-3.1-flash-image-preview

#