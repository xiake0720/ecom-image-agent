# 本文件只提供安全占位，不要提交真实 key。
# 本地开发可复制为 `.env`，或改用 `.streamlit/secrets.toml`。

# ------------------------------
# 基础运行配置
# ------------------------------
ECOM_IMAGE_AGENT_ENV=dev
ECOM_IMAGE_AGENT_ENABLE_MOCK_PROVIDERS=true
ECOM_IMAGE_AGENT_ENABLE_OCR_QC=false
ECOM_IMAGE_AGENT_DEFAULT_FONT_PATH=assets/fonts/NotoSansSC-Regular.otf
ECOM_IMAGE_AGENT_PROVIDER_TIMEOUT_SECONDS=120

# ------------------------------
# 预算模式
# local:      低配机本地调试，默认 text=zhipu_glm47_flash, vision=mock, image=mock
# cheap:      低成本云端优先，默认 text=zhipu_glm47_flash, vision=zhipu, image=dashscope
# balanced:   兼顾成本与质量，默认 text=nvidia, vision=nvidia, image=runapi
# production: 保持当前生产主链路，默认 text=nvidia, vision=nvidia, image=runapi
# ------------------------------
ECOM_IMAGE_AGENT_BUDGET_MODE=production

# ------------------------------
# Provider 模式
# mock: 本地 mock/provider 占位
# real: 走真实 provider 路由
# ------------------------------
ECOM_IMAGE_AGENT_TEXT_PROVIDER_MODE=mock
ECOM_IMAGE_AGENT_VISION_PROVIDER_MODE=mock
ECOM_IMAGE_AGENT_IMAGE_PROVIDER_MODE=mock

# ------------------------------
# Provider 别名
# text:   zhipu_glm47_flash / zhipu_glm47 / zhipu / nvidia / ollama / dashscope
# vision: nvidia / dashscope / zhipu
# image:  runapi / dashscope / zhipu / mock
# 不填写时，会按 budget mode 自动选择。
# ------------------------------
ECOM_IMAGE_AGENT_TEXT_PROVIDER=zhipu_glm47_flash
ECOM_IMAGE_AGENT_VISION_PROVIDER=
ECOM_IMAGE_AGENT_IMAGE_PROVIDER=

# ------------------------------
# 文本模型
# ECOM_IMAGE_AGENT_TEXT_MODEL 是当前推荐文本模型字段。
# ECOM_IMAGE_AGENT_TEXT_MODEL_ID 保留兼容旧配置。
# ------------------------------
ECOM_IMAGE_AGENT_TEXT_MODEL=glm-4.7-flash
ECOM_IMAGE_AGENT_TEXT_MODEL_ID=
ECOM_IMAGE_AGENT_VISION_MODEL_ID=

# ------------------------------
# 兼容旧模型开关
# ------------------------------
ECOM_IMAGE_AGENT_TEXT_MODEL_PROVIDER=qwen
ECOM_IMAGE_AGENT_VISION_MODEL_PROVIDER=qwen
ECOM_IMAGE_AGENT_QWEN_MODEL_ID=qwen/qwen3.5-122b-a10b
ECOM_IMAGE_AGENT_GLM5_MODEL_ID=z-ai/glm5

# ------------------------------
# NVIDIA
# balanced / production 主链路仍默认使用 NVIDIA 文本与视觉。
# ------------------------------
ECOM_IMAGE_AGENT_NVIDIA_API_KEY=
ECOM_IMAGE_AGENT_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
ECOM_IMAGE_AGENT_NVIDIA_TEXT_MODEL=z-ai/glm5
ECOM_IMAGE_AGENT_NVIDIA_VISION_API_KEY=
ECOM_IMAGE_AGENT_NVIDIA_VISION_BASE_URL=https://integrate.api.nvidia.com/v1
ECOM_IMAGE_AGENT_NVIDIA_VISION_MODEL=qwen/qwen3.5-122b-a10b

# ------------------------------
# DashScope
# 当前仍主要用于配置与路由预留。
# ------------------------------
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ------------------------------
# 智谱 Zhipu
# 文本调试链路推荐优先使用 OpenAI-compatible 接口。
# ------------------------------
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# ------------------------------
# Ollama
# 仍保留支持，但不再作为低配机默认文本链路。
# ------------------------------
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ------------------------------
# RunAPI 图片主链路
# ------------------------------
ECOM_IMAGE_AGENT_RUNAPI_API_KEY=
ECOM_IMAGE_AGENT_RUNAPI_IMAGE_BASE_URL=https://runapi.co
ECOM_IMAGE_AGENT_RUNAPI_IMAGE_MODEL=gemini-2.5-flash-image
