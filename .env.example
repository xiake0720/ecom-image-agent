# 修改 `.env` 后需要重启 FastAPI / Vite 进程

# ------------------------------
# FastAPI 基础配置
# ------------------------------
ECOM_DEBUG=false
ECOM_API_PREFIX=/api
ECOM_API_V1_PREFIX=/api/v1
ECOM_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
ECOM_STORAGE_ROOT=storage
ECOM_OUTPUTS_ROOT=outputs/tasks
ECOM_TEMPLATE_ROOT=backend/templates

# ------------------------------
# PostgreSQL + SQLAlchemy Async
# ------------------------------
ECOM_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/ecom_image_agent
ECOM_DATABASE_ECHO=false

# ------------------------------
# 腾讯云 COS（默认关闭，本地开发仍可走本地文件）
# ------------------------------
ECOM_COS_ENABLED=false
ECOM_COS_SECRET_ID=
ECOM_COS_SECRET_KEY=
ECOM_COS_REGION=ap-guangzhou
ECOM_COS_BUCKET=
ECOM_COS_PUBLIC_HOST=
ECOM_COS_SIGN_EXPIRE_SECONDS=600
ECOM_COS_MAX_IMAGE_SIZE_BYTES=20971520
ECOM_COS_ALLOWED_IMAGE_MIME_TYPES=["image/png","image/jpeg","image/webp"]

# ------------------------------
# Celery + Redis（默认关闭，本地无 Redis 时仍用进程内 fallback）
# ------------------------------
ECOM_CELERY_ENABLED=false
ECOM_REDIS_URL=redis://127.0.0.1:6379/0
ECOM_CELERY_BROKER_URL=redis://127.0.0.1:6379/0
ECOM_CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
ECOM_CELERY_TASK_ALWAYS_EAGER=false
ECOM_CELERY_TASK_SERIALIZER=json
ECOM_CELERY_ACCEPT_CONTENT=["json"]
ECOM_CELERY_RESULT_SERIALIZER=json
ECOM_CELERY_TASK_TIME_LIMIT_SECONDS=3600
ECOM_CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=3300
ECOM_CELERY_MAX_RETRIES=1
ECOM_CELERY_RETRY_COUNTDOWN_SECONDS=30

# ------------------------------
# JWT / Refresh Token
# ------------------------------
ECOM_AUTH_JWT_SECRET_KEY=change-me-in-production
ECOM_AUTH_JWT_ALGORITHM=HS256
ECOM_AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
ECOM_AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30
ECOM_AUTH_REFRESH_COOKIE_NAME=ecom_refresh_token
ECOM_AUTH_REFRESH_COOKIE_SECURE=false
ECOM_AUTH_REFRESH_COOKIE_SAMESITE=lax
ECOM_AUTH_REFRESH_COOKIE_DOMAIN=
ECOM_AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
ECOM_AUTH_TOKEN_HASH_SECRET=change-me-too
ECOM_COMPAT_TASK_USER_EMAIL=compat-task-user@local.invalid
ECOM_COMPAT_TASK_USER_NICKNAME=系统兼容任务账户

# ------------------------------
# 生成引擎基础配置
# ------------------------------
ECOM_IMAGE_AGENT_ENV=dev
ECOM_IMAGE_AGENT_ENABLE_MOCK_PROVIDERS=true
ECOM_IMAGE_AGENT_ENABLE_NODE_CACHE=true
ECOM_IMAGE_AGENT_ENABLE_FILE_LOG=true
ECOM_IMAGE_AGENT_LOG_LEVEL=INFO
ECOM_IMAGE_AGENT_PROVIDER_TIMEOUT_SECONDS=600
ECOM_IMAGE_AGENT_DEFAULT_FONT_PATH=assets/fonts/NotoSansSC-Regular.otf

# ------------------------------
# v2 固定业务默认值
# ------------------------------
ECOM_IMAGE_AGENT_DEFAULT_PLATFORM=tmall
ECOM_IMAGE_AGENT_DEFAULT_SHOT_COUNT=8
ECOM_IMAGE_AGENT_DEFAULT_IMAGE_ASPECT_RATIO=1:1
ECOM_IMAGE_AGENT_DEFAULT_IMAGE_SIZE=1K
ECOM_IMAGE_AGENT_ENABLE_OVERLAY_FALLBACK=true

# ------------------------------
# Provider 模式
# real: 使用真实 provider
# mock: 使用本地占位 provider
# ------------------------------
ECOM_IMAGE_AGENT_TEXT_PROVIDER_MODE=real
ECOM_IMAGE_AGENT_IMAGE_PROVIDER_MODE=real

# ------------------------------
# RunAPI 文本配置
# ------------------------------
ECOM_IMAGE_AGENT_RUNAPI_API_KEY=
ECOM_IMAGE_AGENT_RUNAPI_TEXT_API_KEY=
ECOM_IMAGE_AGENT_RUNAPI_TEXT_BASE_URL=https://runapi.co/v1
ECOM_IMAGE_AGENT_RUNAPI_TEXT_MODEL=gpt-5-nano

# ------------------------------
# RunAPI 图片配置
# ------------------------------
ECOM_IMAGE_AGENT_RUNAPI_IMAGE_BASE_URL=https://runapi.co
ECOM_IMAGE_AGENT_RUNAPI_IMAGE_MODEL=gemini-3.1-flash-image-preview
