# 当前默认平台：DashScope（阿里云百炼）
# 修改环境变量或 `.env` 后，必须重启 Streamlit 进程。

# ------------------------------
# 基础运行配置
# ------------------------------
ECOM_IMAGE_AGENT_ENV=dev
ECOM_IMAGE_AGENT_ENABLE_MOCK_PROVIDERS=true
ECOM_IMAGE_AGENT_ENABLE_OCR_QC=false
ECOM_IMAGE_AGENT_DEFAULT_FONT_PATH=assets/fonts/NotoSansSC-Regular.otf
ECOM_IMAGE_AGENT_PROVIDER_TIMEOUT_SECONDS=120
ECOM_IMAGE_AGENT_TEXT_RENDER_PRESET=premium_minimal
ECOM_IMAGE_AGENT_TEXT_RENDER_ADAPTIVE_STYLE_ENABLED=true
ECOM_IMAGE_AGENT_TEXT_RENDER_MIN_TITLE_FONT_SIZE=40
ECOM_IMAGE_AGENT_TEXT_RENDER_MIN_SUBTITLE_FONT_SIZE=24
ECOM_IMAGE_AGENT_TEXT_RENDER_MIN_BULLETS_FONT_SIZE=22
ECOM_IMAGE_AGENT_TEXT_RENDER_MIN_CTA_FONT_SIZE=22

# ------------------------------
# 预算模式
# 当前 local / cheap / balanced / production 都统一走 DashScope，
# 先消除多平台分流的不确定性。
# ------------------------------
ECOM_IMAGE_AGENT_BUDGET_MODE=production

# ------------------------------
# Provider 模式
# mock: 仅显式 fallback / 本地占位
# real: 走当前 DashScope 主链
# ------------------------------
ECOM_IMAGE_AGENT_TEXT_PROVIDER_MODE=real
ECOM_IMAGE_AGENT_VISION_PROVIDER_MODE=real
ECOM_IMAGE_AGENT_IMAGE_PROVIDER_MODE=real

# ------------------------------
# Provider 别名
# 默认 alias 全部收敛到 dashscope
# ------------------------------
ECOM_IMAGE_AGENT_TEXT_PROVIDER=dashscope
ECOM_IMAGE_AGENT_VISION_PROVIDER=dashscope
ECOM_IMAGE_AGENT_IMAGE_PROVIDER=dashscope

# ------------------------------
# DashScope 默认模型
# plan_shots / generate_copy / build_prompts -> qwen-plus
# analyze_product -> qwen3-vl-flash
# render_images -> wanx2.1-t2i-turbo
# ------------------------------
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ECOM_IMAGE_AGENT_TEXT_MODEL=qwen-plus
ECOM_IMAGE_AGENT_VISION_MODEL=qwen3-vl-flash
ECOM_IMAGE_AGENT_IMAGE_MODEL=wanx2.1-t2i-turbo
ECOM_IMAGE_AGENT_IMAGE_EDIT_PROVIDER=dashscope
ECOM_IMAGE_AGENT_IMAGE_EDIT_MODEL=wan2.6-image
ECOM_IMAGE_AGENT_IMAGE_EDIT_ENABLED=true
ECOM_IMAGE_AGENT_IMAGE_EDIT_PREFER_MULTI_IMAGE=true
ECOM_IMAGE_AGENT_IMAGE_EDIT_MAX_REFERENCE_IMAGES=2
ECOM_IMAGE_AGENT_IMAGE_ALLOW_MOCK_FALLBACK=false

# ------------------------------
# 兼容旧 provider 的保留配置
# 这些实现仍保留，但不再作为默认主路由
# ------------------------------
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
OLLAMA_BASE_URL=http://127.0.0.1:11434
ECOM_IMAGE_AGENT_NVIDIA_API_KEY=
ECOM_IMAGE_AGENT_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
ECOM_IMAGE_AGENT_NVIDIA_TEXT_MODEL=
ECOM_IMAGE_AGENT_NVIDIA_VISION_API_KEY=
ECOM_IMAGE_AGENT_NVIDIA_VISION_BASE_URL=https://integrate.api.nvidia.com/v1
ECOM_IMAGE_AGENT_NVIDIA_VISION_MODEL=
ECOM_IMAGE_AGENT_RUNAPI_API_KEY=
ECOM_IMAGE_AGENT_RUNAPI_IMAGE_BASE_URL=https://runapi.co
ECOM_IMAGE_AGENT_RUNAPI_IMAGE_MODEL=gemini-2.5-flash-image
