{
  "template_name": "tea_tmall_premium_v2",
  "platform": "tmall",
  "category": "tea",
  "canvas": {
    "aspect_ratio": "3:4",
    "screens_per_page": 1,
    "layout_mode": "single_screen_vertical_poster"
  },
  "supported_style_presets": [
    "tea_tmall_premium_light",
    "tea_tmall_premium_dark"
  ],
  "default_style_preset": "tea_tmall_premium_light",
  "recommended_page_count": {
    "min": 8,
    "max": 12
  },
  "global_style_anchor": "天猫高端茶叶详情图，3:4 单屏竖版海报，版式克制留白，蓝白与浅米纸感统一，中文信息层级清晰，包装主体稳定，质感真实，不做左右分屏和拼贴。",
  "page_rhythm": [
    "首屏建立品牌与包装锚点",
    "中段用茶叶细节与场景价值支撑判断",
    "尾段用参数与品牌信任收束购买心智"
  ],
  "density_limits": {
    "headline_best_max": 8,
    "headline_hard_max": 12,
    "subheadline_best_max": 16,
    "subheadline_hard_max": 24,
    "selling_point_word_range": "2-6",
    "selling_point_count_range": "2-4",
    "supporting_copy_best_range": "20-40"
  },
  "page_sequences": {
